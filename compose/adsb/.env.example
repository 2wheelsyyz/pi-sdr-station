# ─── VA3YMX ADS-B feeder — environment TEMPLATE ──────────────────────────────
# Copy to ".env" and fill in.  The real .env holds secrets and is .gitignore'd.

# Station location — REQUIRED and MLAT-critical. Use ~5 decimal places.
FEEDER_LAT=                      # e.g. 43.70000  (your antenna latitude)
FEEDER_LONG=                     # e.g. -79.50000 (your antenna longitude)
FEEDER_ALT_M=                    # antenna height ASL = ground elevation + antenna AGL (metres)
FEEDER_TZ=America/Toronto        # your IANA timezone

# Stable UUID for the community aggregators (generate once):
#   cat /proc/sys/kernel/random/uuid   (or: uuidgen)
ULTRAFEEDER_UUID=PUT-A-GENERATED-UUID-HERE

# ─── SDR ──────────────────────────────────────────────────────────────────────
ADSB_SDR_SERIAL=1090             # EEPROM serial of the ADS-B dongle (see docs/03)
ADSB_GAIN=autogain               # or a fixed number like 42

# ─── Premium aggregator credentials (see docs/04 + docs/08) ──────────────────
FEEDER_FA_ID=                    # FlightAware feeder-id (reuse existing to keep your site)
FR24_SHARING_KEY=                # FlightRadar24 sharing key
RADARBOX_SHARING_KEY=            # AirNav RadarBox sharing key
PLANEFINDER_SHARECODE=           # PlaneFinder share code
OPENSKY_USERNAME=                # OpenSky Network username
OPENSKY_SERIAL=                  # OpenSky Network feeder serial
ADSBX_UUID=PUT-A-GENERATED-UUID-HERE   # ADSBExchange (new for this build)
