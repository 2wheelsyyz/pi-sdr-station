# ─── OpenWebRX admin login — TEMPLATE ────────────────────────────────────────
# Copy to ".env" (gitignored) and set your password, then apply it with:
#   ./scripts/openwebrx-set-password.sh        (run on the Pi)
#
# NOTE: this image stores its login in users.json, NOT from these env vars, so
# the helper script writes the password into OpenWebRX via its admin CLI.
OPENWEBRX_ADMIN_USER=admin
OPENWEBRX_ADMIN_PASSWORD=change-me
